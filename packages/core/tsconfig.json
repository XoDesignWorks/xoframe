{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["src/index.ts", "src/debug.ts", "src/embed.ts", "src/thumbhash.ts", "src/blurhash.ts", "src/masonry.ts", "src/skeleton.ts", "src/visibility.ts", "src/lightbox.ts", "src/fonts.ts", "src/vitals.ts", "src/video.ts", "src/slider.ts", "src/react.tsx"]
}
